{
  "expo": {
    "name": "Mundo do Circo",
    "slug": "mundo-do-circo",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mundo-do-circo",
    "icon": "./public/icons/Icon-iOS-Default-1024x1024@1x.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./public/icons/Icon-iOS-Default-1024x1024@1x.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF8F0",
        "foregroundImage": "./public/icons/Icon-iOS-Default-1024x1024@1x.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./public/icons/Icon-iOS-Default-256x256@1x.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./public/icons/Icon-iOS-Default-128x128@1x.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image"
    ]
  }
}